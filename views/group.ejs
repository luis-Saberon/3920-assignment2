<%- include("templates/header") %> 
<table>
  <% if(!emptyRoom) { %>
   <% for(var i = 0; i < seen_messages.length; i++) { %>
    <tr>
      <%- include('templates/message', {username: seen_messages[i].username, timestamp: seen_messages[i].sent_datetime, text: seen_messages[i].text}) %>
    </tr>  
    <% } %>
    <% if(unseen_messages.length > 0) { %>
    <tr><td>unseen messages</td></tr>
    <% for(var i = 0; i < unseen_messages.length; i++) { %>
    <tr>
      <%- include('templates/message', {username: seen_messages[i].username, timestamp: seen_messages[i].sent_datetime, text: seen_messages[i].text}) %>
    </tr>  
    <% } %>
    <% } %>
  <% } else { %>
    <tr><td>No messages have been sent yet!</td></tr> 
    <% } %>
</table>
<form action="newMessage/room_user_id/<%= room_user_id %>" method="post">
  <textarea class="text"name="message" rows="2" cols="10" placeholder="Send a text to the group!" ></textarea>
  <button>Submit</button>
</form>
<%- include("templates/footer") %> 